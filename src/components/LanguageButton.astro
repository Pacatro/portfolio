---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer>
    <a class="language-button" data-current-lang={lang}>
        {t('language.title')}
    </a>
</footer>

<script>
    const button = document.querySelector('.language-button') as HTMLButtonElement;

    function changeLanguage(): void {
        const currentLang = button.dataset.currentLang;
        const newLang = currentLang === 'es' ? 'en' : 'es';
        const newPath = newLang === 'es' ? '/' : '/en/';
        const currentPath = window.location.pathname.split('/').slice(2).join('/');
        const newUrl = `${newPath}${currentPath}${window.location.search}${window.location.hash}`;
        window.location.href = newUrl;
    }

    button.addEventListener('click', changeLanguage);
</script>

<style>
    footer {
        display: flex;
        justify-content: flex-end;
        padding: 1rem;
        padding-right: 3rem;
        position: fixed;
        bottom: 0;
        right: 0;
    }

    .language-switcher {
        right: 1rem;
        z-index: 1000;
        display: flex;
        justify-content: flex-end;
    }

    .language-button {
        list-style: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
        border-radius: 7px;
        border: 2px solid white;
        background-color: transparent;
        color: white;
        font-size: 1rem;
        font-weight: bold;
        width: 5rem;
        height: 3rem;
        cursor: pointer;
        transition: transform 0.3s ease, box-shadow 0.3s ease, opacity 0.3s ease;
    }

    .language-button:is(:hover, :focus) {
        background-position: 0;
        transform: translateY(-5px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        opacity: 1;
    }

    .language-button:active {
        transform: translateY(0);
        box-shadow: none;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        opacity: 0.9;
    }
</style>