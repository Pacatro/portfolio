---
interface Props {
    description: string;
}

const { description } = Astro.props;
---

<section class="about-me-section">
    <h2>About me</h2>
    <p>{description}</p>
</section>

<style>
    .about-me-section {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
    }
    
</style>