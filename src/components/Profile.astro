---
import { Image } from 'astro:assets';
import SocialIcons from './SocialIcons.astro'; // Asegúrate de tener este componente disponible

interface Props {
	name: string;
    image: string;
    description: string;
}

const { name, image, description } = Astro.props;
---

<div class='profile'>
    <Image
        class='image-container' 
        src={image} 
        alt={name} 
        width={200} 
        height={200} 
        format="webp" 
        quality={80} 
        decoding="async"
        loading="lazy"
    />
    <div class='profile-info'>
        <h1>Hi! I'm {name}</h1>
        <p>{description}</p>
        <SocialIcons />
    </div>
</div>

<style>
    .profile {
		width: 100%;
		display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        padding-top: 2rem;
	}

    .image-container {
        margin-top: 1rem;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid white;
        margin-right: 2rem;
    }
    
    img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
        color: white;
        margin-bottom: 0.1rem;
	}

	p {
		font-size: 1.5rem;
		font-weight: 600;
		line-height: 1;
		color: snow;
	}
</style>
