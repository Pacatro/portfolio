---
interface Props {
	name: string;
    image: string;
    description: string;
}

const { name, image, description } = Astro.props;
---

<div class='profile'>
    <div class='image-container'>
        <img src={image} alt={name + '\'s profile image'} />
      </div>
    <div class='profile-info'>
        <h1>Hi! I'm {name}</h1>
        <p>{description}</p>
    </div>
</div>

<style>
    .profile {
		width: 100%;
		display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        padding-top: 2rem;
        margin-bottom: 3rem;
	}

    .image-container {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        overflow: hidden;
        border: 5px solid white;
        margin-right: 2rem;
    }
    
    img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
        color: white;
        margin-bottom: 1rem;
	}

	p {
		font-size: 1.5rem;
		font-weight: 600;
		line-height: 1;
		text-align: center;
		color: snow;
	}
</style>